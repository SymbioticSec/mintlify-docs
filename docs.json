{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Symbiotic Security",
  "colors": {
    "primary": "#C45D97",
    "light": "#C45D97",
    "dark": "#C45D97"
  },
  "favicon": "images/favicon_symbiotic.png",
  "icons": {
    "library": "lucide"
  },
  "interaction": {
    "drilldown": true
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://symbioticsec.ai",
          "icon": "globe"
        },
        {
          "anchor": "Changelog",
          "href": "https://symbioticsecurity.mintlify.app/changelog",
          "icon": "logs"
        }
      ]
    },
    "products": [
      {
        "product": "Code",
        "description": "Our secure coding agent",
        "icon": "square-terminal",
        "pages": [
          "code/get_started",
          {
            "group": "Commands",
            "pages": [
              "code/commands/common_commands"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "code/features/custom_commands",
              "code/features/tool_permisisons"
            ]
          }
        ]
      },
      {
        "product": "Flow",
        "description": "Our security scanning solution",
        "icon": "search-code",
        "dropdowns": [
          {
            "dropdown": "Devs",
            "icon": "binary",
            "groups": [
              {
                "group": "Getting started",
                "pages": [
                  "flow/devs/intro/intro",
                  "flow/devs/intro/quickstart"
                ]
              },
              {
                "group": "Tools",
                "pages": [
                  {
                    "group": "IDE extension",
                    "pages": [
                      "flow/devs/discover_extension/detection",
                      "flow/devs/discover_extension/treeview",
                      "flow/devs/discover_extension/details",
                      "flow/devs/discover_extension/deep_remediation",
                      "flow/devs/discover_extension/hover",
                      "flow/devs/discover_extension/status"
                    ]
                  },
                  "flow/devs/discover_extension/MCP",
                  "flow/devs/discover_extension/CLI"
                ]
              },
              {
                "group": "Configurations",
                "pages": [
                  "flow/devs/actions/configure_detection",
                  "flow/devs/actions/ignore",
                  "flow/devs/actions/false_positive"
                ]
              },
              {
                "group": "Support",
                "pages": [
                  "flow/devs/support/share_logs",
                  "flow/devs/support/support_bundle",
                  "flow/devs/support/common_problems",
                  "flow/devs/support/commands"
                ]
              }
            ]
          },
          {
            "dropdown": "Admins",
            "icon": "user-cog",
            "groups": [
              {
                "group": "Admin features",
                "pages": [
                  "flow/admins/user_management",
                  "flow/admins/webhooks",
                  "flow/admins/guardrails"
                ]
              },
              {
                "group": "PR & CI",
                "pages": [
                  "flow/admins/vcs_integration",
                  "flow/admins/github_integration",
                  "flow/admins/setup_CI_integration"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "images/logo/logo horizontal_black.svg",
    "dark": "images/logo/logo horizontal_white.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@symbioticsec.ai"
      },
      {
        "label": "Status",
        "href": "https://status.symbioticsec.ai/"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Go to your portal",
      "href": "https://app.symbioticsec.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/symbiotic-security"
    }
  }
}